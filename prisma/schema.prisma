generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  name      String?
  phone     String?
  country   String     @default("DK")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  orders    Order[]
  cart      Cart?
  sessions  Session[]
  addresses Address[]
  reviews   Review[]

  @@index([email])
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model Product {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  price       Float
  salePrice   Float?
  images      String[]
  category    String
  tags        String[]
  stock       Int      @default(0)
  sku         String   @unique
  variants    Json?
  isFeatured  Boolean  @default(false)
  isActive    Boolean  @default(true)
  viewCount   Int      @default(0)
  rating      Float?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems      OrderItem[]
  cartItems       CartItem[]
  reviews         Review[]
  embeddings      ProductEmbedding?
  productVariants ProductVariant[]

  @@index([category])
  @@index([isActive])
  @@index([isFeatured])
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  sku       String   @unique
  name      String
  attributes Json
  stock     Int      @default(0)
  price     Float?
  images    String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([sku])
}

model ProductEmbedding {
  id           String   @id @default(cuid())
  productId    String   @unique
  embedding    Float[]
  description  String   @db.Text

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int      @default(1)

  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
}

model Discount {
  id        String   @id @default(cuid())
  code      String   @unique
  type      String
  amount    Float
  minPurchase Float?
  maxUses   Int?
  usedCount Int      @default(0)
  expiresAt DateTime?
  isActive  Boolean  @default(true)

  orders    Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([isActive])
}

model Order {
  id              String   @id @default(cuid())
  orderNumber     String   @unique
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  subtotal        Float
  tax             Float    @default(0)
  shippingCost    Float    @default(0)
  discountAmount  Float    @default(0)
  total           Float

  status          String   @default("pending")
  paymentStatus   String   @default("unpaid")

  paymentMethod   String
  stripeSessionId String?
  transactionId   String?

  discountId      String?
  discount        Discount? @relation(fields: [discountId], references: [id])

  shippingAddress Json
  billingAddress  Json?
  trackingNumber  String?

  guestEmail      String?
  guestPhone      String?

  items           OrderItem[]
  metadata        Json?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([orderNumber])
  @@index([discountId])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  street    String
  city      String
  postalCode String
  country   String   @default("DK")
  phone     String?
  isDefault Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  rating    Int
  title     String?
  comment   String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, userId])
  @@index([productId])
  @@index([userId])
  @@index([rating])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}
